# Blog API — Environment Variables
# Copy this to .env and fill in your values.
# nub --env-file .env src/index.ts

# Encryption key for session cookies (minimum 32 characters).
# Generate with: openssl rand -base64 32
SESSION_PASSWORD=change-me-to-a-32-char-string!!!!

# SQLite database URL. Use file:./data.db for persistent storage,
# or a remote libsql URL, or :memory: for ephemeral (default).
DATABASE_URL=file:./data.db

# HTTP server port (defaults to 3000).
# PORT=8080

# Log level: debug | info | warn | error | silent (defaults to info).
# LOG_LEVEL=info
